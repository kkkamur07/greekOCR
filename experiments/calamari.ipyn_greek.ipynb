      "source": [
        "import subprocess, tempfile\n",
        "from pathlib import Path\n",
        "from PIL import Image\n",
        "from IPython.display import display\n",
        "\n",
        "REPO = Path(\"/home/math/gupta/work/greek_byzantine/greek-foundation\")\n",
        "BASE_CHECKPOINT = REPO / \"outputs\" / \"calamari-greek-bible\" / \"best.ckpt\"\n",
        "FINETUNED_CHECKPOINT = REPO / \"outputs\" / \"calamari-greek-export2-finetune\" / \"best.ckpt\"\n",
        "CHECKPOINT = FINETUNED_CHECKPOINT  # used by later upload-prediction cells\n",
        "DATA_ROOT = REPO / \"dataset\" / \"calamari_finetune_export2\"\n",
        "EVAL_DIR = DATA_ROOT / \"val\"   # 17 validation lines from export 2\n",
        "\n",
        "image_exts = (\"*.png\", \"*.jpg\", \"*.jpeg\", \"*.tif\", \"*.tiff\")\n",
        "test_images = sorted(p for pattern in image_exts for p in EVAL_DIR.glob(pattern))\n",
        "\n",
        "print(f\"Before fine-tuning checkpoint: {BASE_CHECKPOINT}\")\n",
        "print(f\"Fine-tuned checkpoint:        {FINETUNED_CHECKPOINT}\")\n",
        "print(f\"Data root:                    {DATA_ROOT}\")\n",
        "print(f\"Eval dir:                     {EVAL_DIR}\")\n",
        "print(f\"{len(test_images)} evaluation images\")\n",
        "\n",
        "assert BASE_CHECKPOINT.exists(), f\"Missing checkpoint: {BASE_CHECKPOINT}\"\n",
        "assert FINETUNED_CHECKPOINT.exists(), f\"Missing checkpoint: {FINETUNED_CHECKPOINT}\"\n",
        "assert EVAL_DIR.exists(), f\"Missing eval dir: {EVAL_DIR}\"\n",
        "assert test_images, f\"No images found in {EVAL_DIR}\"\n",
        "\n",
        "def predict_with_checkpoint(checkpoint):\n",
        "    tmp = tempfile.mkdtemp()\n",
        "    cmd = [\n",
        "        str(REPO / \".venv/bin/calamari-predict\"),\n",
        "        \"--checkpoint\", str(checkpoint),\n",
        "        \"--data.images\", *[str(p) for p in test_images],\n",
        "        \"--data.pred_extension\", \".pred.txt\",\n",
        "        \"--output_dir\", tmp,\n",
        "        \"--predictor.device.gpus\", \"0\",\n",
        "    ]\n",
        "    proc = subprocess.run(cmd, capture_output=True, text=True)\n",
        "    if proc.returncode != 0:\n",
        "        print(proc.stderr[-1000:])\n",
        "        raise RuntimeError(f\"calamari-predict failed for {checkpoint}\")\n",
        "\n",
        "    preds = {}\n",
        "    for f in Path(tmp).glob(\"*.pred.txt\"):\n",
        "        preds[f.stem.replace(\".pred\", \"\")] = f.read_text(\"utf-8\").strip()\n",
        "    return preds\n",
        "\n",
        "print(\"Running predictions with original Bible checkpoint...\")\n",
        "base_predictions = predict_with_checkpoint(BASE_CHECKPOINT)\n",
        "print(f\"Done. {len(base_predictions)} original-checkpoint predictions loaded.\")\n",
        "\n",
        "print(\"Running predictions with fine-tuned checkpoint...\")\n",
        "finetuned_predictions = predict_with_checkpoint(FINETUNED_CHECKPOINT)\n",
        "print(f\"Done. {len(finetuned_predictions)} fine-tuned predictions loaded.\")\n"
      ]
    },
