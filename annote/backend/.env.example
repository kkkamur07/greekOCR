# Copy to .env and adjust as needed:
#   cp .env.example .env

# Filesystem root for pages, transcriptions, annotations, and exports
ANNOTE_DATA_ROOT=../data

# API bind address and port
ANNOTE_HOST=127.0.0.1
ANNOTE_PORT=5050

# Comma-separated browser origins allowed to call the API (Next.js dev server)
ANNOTE_CORS_ORIGINS=http://localhost:3000

# Auto-reload on code changes (local dev)
ANNOTE_RELOAD=true
