  "components": {
    "schemas": {
      "Body_post_import_page_pages_import_post": {
        "properties": {
          "image": {
            "type": "string",
            "format": "binary",
            "title": "Image"
          },
          "transcription": {
            "anyOf": [
              {
                "type": "string",
                "format": "binary"
              },
              {
                "type": "null"
              }
            ],
            "title": "Transcription"
          }
        },
        "type": "object",
        "required": [
          "image"
        ],
        "title": "Body_post_import_page_pages_import_post"
      },
      "ExportMetadata": {
        "properties": {
          "exported_at": {
            "type": "string",
            "title": "Exported At"
          },
          "content_hash": {
            "type": "string",
            "title": "Content Hash"
          }
        },
        "type": "object",
        "required": [
          "exported_at",
          "content_hash"
        ],
        "title": "ExportMetadata"
      },
      "ExportRequest": {
        "properties": {
          "binarize": {
            "type": "boolean",
            "title": "Binarize",
            "default": false
          }
        },
        "type": "object",
        "title": "ExportRequest"
      },
      "ExportResponse": {
        "properties": {
          "exported_count": {
            "type": "integer",
            "title": "Exported Count"
          },
          "warnings": {
            "$ref": "#/components/schemas/ExportWarnings"
          },
          "steps": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Steps"
          }
        },
        "type": "object",
        "required": [
          "exported_count",
          "warnings",
          "steps"
        ],
        "title": "ExportResponse"
      },
      "ExportWarnings": {
        "properties": {
          "unpaired_segments": {
            "items": {
              "type": "integer"
            },
            "type": "array",
            "title": "Unpaired Segments"
          },
          "unused_text_lines": {
            "items": {
              "type": "integer"
            },
            "type": "array",
            "title": "Unused Text Lines"
          }
        },
        "type": "object",
        "required": [
          "unpaired_segments",
          "unused_text_lines"
        ],
        "title": "ExportWarnings"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          }
        },
        "type": "object",
        "required": [
          "status"
        ],
        "title": "HealthResponse"
      },
      "PageAnnotation": {
        "properties": {
          "segments": {
            "items": {
              "$ref": "#/components/schemas/Segment"
            },
            "type": "array",
            "title": "Segments"
          },
          "export_metadata": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ExportMetadata"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "type": "object",
        "title": "PageAnnotation"
      },
      "PageListResponse": {
        "properties": {
          "pages": {
            "items": {
              "$ref": "#/components/schemas/PageSummary"
            },
            "type": "array",
            "title": "Pages"
          }
        },
        "type": "object",
        "required": [
          "pages"
        ],
        "title": "PageListResponse"
      },
      "PageSummary": {
        "properties": {
          "stem": {
            "type": "string",
            "title": "Stem"
          },
          "has_transcription": {
            "type": "boolean",
            "title": "Has Transcription"
          },
          "segment_count": {
            "type": "integer",
            "title": "Segment Count"
          },
          "export_dirty": {
            "type": "boolean",
            "title": "Export Dirty"
          }
        },
        "type": "object",
        "required": [
          "stem",
          "has_transcription",
          "segment_count",
          "export_dirty"
        ],
        "title": "PageSummary"
      },
      "Segment": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "number": {
            "type": "integer",
            "title": "Number"
          },
          "kind": {
            "type": "string",
            "enum": [
              "polygon",
              "rectangle"
            ],
            "title": "Kind"
          },
          "points": {
            "items": {
              "items": {
                "type": "number"
              },
              "type": "array"
            },
            "type": "array",
            "title": "Points"
          },
          "paired_text_line_index": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Paired Text Line Index"
          },
          "text_override": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Text Override"
          }
        },
        "type": "object",
        "required": [
          "id",
          "number",
          "kind",
          "points"
        ],
        "title": "Segment"
      },
      "TextLineOut": {
        "properties": {
          "index": {
            "type": "integer",
            "title": "Index"
          },
          "text": {
            "type": "string",
            "title": "Text"
          }
        },
        "type": "object",
        "required": [
          "index",
          "text"
        ],
        "title": "TextLineOut"
      },
      "TranscriptionResponse": {
        "properties": {
          "raw_text": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Raw Text"
          },
          "text_lines": {
            "items": {
              "$ref": "#/components/schemas/TextLineOut"
            },
            "type": "array",
            "title": "Text Lines"
          },
          "status": {
            "type": "string",
            "title": "Status",
            "default": "ok"
          }
        },
        "type": "object",
        "required": [
          "raw_text",
          "text_lines"
        ],
        "title": "TranscriptionResponse"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}