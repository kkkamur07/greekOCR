  "components": {
    "schemas": {
      "AutoSegmentRequest": {
        "properties": {
          "replace": {
            "type": "boolean",
            "title": "Replace",
            "description": "Replace existing segments. If false, append Kraken lines after current segments.",
            "default": true
          },
          "pair_transcription": {
            "type": "boolean",
            "title": "Pair Transcription",
            "description": "Pair segments to transcription text lines in reading order when available.",
            "default": true
          }
        },
        "type": "object",
        "title": "AutoSegmentRequest",
        "description": "Run Kraken line segmentation on a page image."
      },
      "Body_post_import_page_pages_import_post": {
        "properties": {
          "image": {
            "type": "string",
            "format": "binary",
            "title": "Image"
          },
          "transcription": {
            "anyOf": [
              {
                "type": "string",
                "format": "binary"
              },
              {
                "type": "null"
              }
            ],
            "title": "Transcription"
          }
        },
        "type": "object",
        "required": [
          "image"
        ],
        "title": "Body_post_import_page_pages_import_post"
      },
      "ExportMetadata": {
        "properties": {
          "exported_at": {
            "type": "string",
            "title": "Exported At"
          },
          "content_hash": {
            "type": "string",
            "title": "Content Hash"
          }
        },
        "type": "object",
        "required": [
          "exported_at",
          "content_hash"
        ],
        "title": "ExportMetadata"
      },
      "ExportResponse": {
        "properties": {
          "exported_count": {
            "type": "integer",
            "title": "Exported Count"
          },
          "warnings": {
            "$ref": "#/components/schemas/ExportWarnings"
          },
          "steps": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Steps"
          }
        },
        "type": "object",
        "required": [
          "exported_count",
          "warnings",
          "steps"
        ],
        "title": "ExportResponse"
      },
      "ExportWarnings": {
        "properties": {
          "unpaired_segments": {
            "items": {
              "type": "integer"
            },
            "type": "array",
            "title": "Unpaired Segments"
          },
          "unused_text_lines": {
            "items": {
              "type": "integer"
            },
            "type": "array",
            "title": "Unused Text Lines"
          }
        },
        "type": "object",
        "required": [
          "unpaired_segments",
          "unused_text_lines"
        ],
        "title": "ExportWarnings"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthResponse": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "version": {
            "type": "string",
            "title": "Version"
          }
        },
        "type": "object",
        "required": [
          "status",
          "version"
        ],
        "title": "HealthResponse"
      },
      "HistoryListResponse": {
        "properties": {
          "snapshots": {
            "items": {
              "$ref": "#/components/schemas/HistorySnapshotSummary"
            },
            "type": "array",
            "title": "Snapshots"
          }
        },
        "type": "object",
        "required": [
          "snapshots"
        ],
        "title": "HistoryListResponse"
      },
      "HistorySnapshotSummary": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "timestamp": {
            "type": "string",
            "title": "Timestamp"
          },
          "reason": {
            "type": "string",
            "title": "Reason"
          },
          "pairing_progress_percent": {
            "type": "integer",
            "title": "Pairing Progress Percent"
          }
        },
        "type": "object",
        "required": [
          "id",
          "timestamp",
          "reason",
          "pairing_progress_percent"
        ],
        "title": "HistorySnapshotSummary"
      },
      "PageAnnotation": {
        "properties": {
          "segments": {
            "items": {
              "$ref": "#/components/schemas/Segment"
            },
            "type": "array",
            "title": "Segments"
          },
          "export_metadata": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/ExportMetadata"
              },
              {
                "type": "null"
              }
            ]
          },
          "locked": {
            "type": "boolean",
            "title": "Locked",
            "default": false
          }
        },
        "type": "object",
        "title": "PageAnnotation"
      },
      "PageListResponse": {
        "properties": {
          "pages": {
            "items": {
              "$ref": "#/components/schemas/PageSummary"
            },
            "type": "array",
            "title": "Pages"
          }
        },
        "type": "object",
        "required": [
          "pages"
        ],
        "title": "PageListResponse"
      },
      "PageSummary": {
        "properties": {
          "stem": {
            "type": "string",
            "title": "Stem"
          },
          "has_transcription": {
            "type": "boolean",
            "title": "Has Transcription"
          },
          "segment_count": {
            "type": "integer",
            "title": "Segment Count"
          },
          "export_dirty": {
            "type": "boolean",
            "title": "Export Dirty"
          },
          "locked": {
            "type": "boolean",
            "title": "Locked",
            "default": false
          },
          "pairing": {
            "$ref": "#/components/schemas/PairingProgress"
          }
        },
        "type": "object",
        "required": [
          "stem",
          "has_transcription",
          "segment_count",
          "export_dirty",
          "pairing"
        ],
        "title": "PageSummary"
      },
      "PairingProgress": {
        "properties": {
          "paired_count": {
            "type": "integer",
            "title": "Paired Count"
          },
          "unpaired_count": {
            "type": "integer",
            "title": "Unpaired Count"
          },
          "text_line_count": {
            "type": "integer",
            "title": "Text Line Count"
          },
          "unused_line_count": {
            "type": "integer",
            "title": "Unused Line Count"
          }
        },
        "type": "object",
        "required": [
          "paired_count",
          "unpaired_count",
          "text_line_count",
          "unused_line_count"
        ],
        "title": "PairingProgress"
      },
      "Segment": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "number": {
            "type": "integer",
            "title": "Number"
          },
          "kind": {
            "type": "string",
            "enum": [
              "polygon",
              "rectangle"
            ],
            "title": "Kind"
          },
          "points": {
            "items": {
              "items": {
                "type": "number"
              },
              "type": "array"
            },
            "type": "array",
            "title": "Points"
          },
          "paired_text_line_index": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Paired Text Line Index"
          },
          "text_override": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Text Override"
          }
        },
        "type": "object",
        "required": [
          "id",
          "number",
          "kind",
          "points"
        ],
        "title": "Segment"
      },
      "TextLineOut": {
        "properties": {
          "index": {
            "type": "integer",
            "title": "Index"
          },
