# Docker Compose development variables. Copy to the repository-root `.env`,
# choose a unique local-only password, and never commit the filled file.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-local-only-password
POSTGRES_DB=kalamos

# Development-only service secrets. Replace before any shared deployment.
JWT_SECRET=replace-with-a-local-only-jwt-secret-at-least-32-bytes
INFERENCE_WEBHOOK_SECRET=replace-with-a-local-only-webhook-secret
INFERENCE_SERVICE_SECRET=replace-with-a-local-only-service-secret
