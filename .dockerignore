**/.DS_Store
**/.env
**/.env.*
**/.mypy_cache
**/.pytest_cache
**/.ruff_cache
**/.venv
**/__pycache__
**/*.pyc
**/node_modules
**/dist
**/build
.cursor
.docker-cache/
.git
.gitignore
agent-transcripts
issues
_support_repo

# Large local-only trees (mounted as volumes in compose, not needed in images)
data/
packaging/

# Tests and docs are not shipped in production images
tests/
docs/
configs/

# Model weights are mounted at runtime, not baked into images. Keep the Python
# package initializer so `from inference.weights import ...` works in the image.
inference/weights
!inference/
!inference/weights/
!inference/weights/__init__.py

# Only the Hub resolver is needed by the inference image.  Docker ignore
# negations must re-include both ancestor directories and concrete files.
# Keep local caches, staging trees, publishing helpers, and bundled weights
# outside the build context.
src/**
!src/
!src/hf/
!src/hf/__init__.py
!src/hf/paths.py
!src/hf/resolve/
!src/hf/resolve/**

# Frontend is built from nomicous/ context; exclude from repo-root API/inference builds
nomicous/frontend/
nomicous/backend/media
nomicous/data/

# Dev-only paths under nomicous
nomicous/backend/tests
