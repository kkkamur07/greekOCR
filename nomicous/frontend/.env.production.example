# Vercel production build env for app.nomicous.com
# Set these in the Vercel project → Settings → Environment Variables.

VITE_API_BASE_URL=https://api.nomicous.com

# Optional: override local helper probe URL (default http://127.0.0.1:8001)
# VITE_INFERENCE_HELPER_URL=http://127.0.0.1:8001

VITE_ENABLE_TEST_JOBS=false
