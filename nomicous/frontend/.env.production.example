# Vercel production build env for app.nomicous.com
# Set these in the Vercel project → Settings → Environment Variables.

NEXT_PUBLIC_API_BASE_URL=https://api.nomicous.com
NEXT_PUBLIC_CSRF_COOKIE_NAME=greekocr-csrf

# Local helper probe URL. This is resolved by the user's browser, not by Vercel.
# Prefer IPv4 because the helper binds to 127.0.0.1. localhost:8001 remains
# supported as an explicit override when the user's system resolves it to IPv4.
NEXT_PUBLIC_INFERENCE_HELPER_URL=http://127.0.0.1:8001

# Any override must remain loopback and also be added to the frontend CSP and the
# helper's explicit runtime CORS origins. Do not put a helper secret here.

NEXT_PUBLIC_ENABLE_TEST_JOBS=false
