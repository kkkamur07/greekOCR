# Production environment (platform API on Vercel + Supabase)
# Copy values into the Vercel project environment settings. Never commit secrets.

ENVIRONMENT=production

# --- Supabase Postgres (see docs/supabase.md) ---
# Set these only in the deployment provider's secret store. The API uses the
# nomicous_api credential; the persistent worker has its own template and
# credential. Migration URLs never belong in the serverless API environment.
DATABASE_URL=
SYNC_DATABASE_URL=

# --- Supabase Storage ---
STORAGE_BACKEND=supabase
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=document-media
MEDIA_WEBP_LOSSLESS=true

# --- Auth ---
JWT_SECRET=replace-with-at-least-32-byte-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
AUTH_RATE_LIMIT_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# --- Browser origins (comma-separated) ---
CORS_ORIGINS=https://app.nomicous.com,https://nomicous.com

# --- Vercel / reverse proxy ---
# Set both only when the request reaches this process through a fixed,
# allowlisted proxy source range. Never use `*`.
BEHIND_PROXY=false
FORWARDED_ALLOW_IPS=

# --- Serverless API: no in-process background workers ---
JOB_WORKER_ENABLED=false
JOB_SSE_NOTIFICATIONS_ENABLED=false

# --- Local OCR is the default ---
# The browser calls the loopback-only helper at http://127.0.0.1:8001 and the
# platform persists authenticated results. No inference service secret is needed.
CLOUD_INFERENCE_ENABLED=false

# --- Optional cloud inference (hosted outside Vercel) ---
# Enable only with a separately deployed platform worker. The Vercel API receives
# callbacks, so it needs only the webhook secret; the worker gets the service secret.
# CLOUD_INFERENCE_ENABLED=true
# INFERENCE_URL=https://inference.nomicous.com
# INFERENCE_WEBHOOK_SECRET=

# --- Safety ---
ENABLE_TEST_JOB_ROUTES=false
