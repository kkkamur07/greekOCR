# Production environment (platform API on Vercel + Supabase)
# Copy values into the Vercel project environment settings. Never commit secrets.

ENVIRONMENT=production

# --- Supabase Postgres (see docs/supabase.md) ---
MIGRATOR_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
SYNC_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# --- Supabase Storage ---
STORAGE_BACKEND=supabase
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=document-media
MEDIA_WEBP_LOSSLESS=true

# --- Auth ---
JWT_SECRET=replace-with-at-least-32-byte-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
AUTH_RATE_LIMIT_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# --- Browser origins (comma-separated) ---
CORS_ORIGINS=https://app.nomicous.com,https://nomicous.com

# --- Vercel / reverse proxy ---
BEHIND_PROXY=true
FORWARDED_ALLOW_IPS=*

# --- Serverless API: no in-process background workers ---
JOB_WORKER_ENABLED=false
JOB_SSE_NOTIFICATIONS_ENABLED=false

# --- Cloud inference (hosted outside Vercel) ---
INFERENCE_URL=https://inference.nomicous.com
INFERENCE_WEBHOOK_SECRET=replace-me
INFERENCE_SERVICE_SECRET=replace-me

# --- Safety ---
ENABLE_TEST_JOB_ROUTES=false
