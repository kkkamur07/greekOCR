# Supabase profile for platform database + storage.
# Copy to backend/core/.env.supabase and fill in credentials. Never commit the filled file.

# --- Database (Supabase Postgres, database name: postgres) ---
# Direct connection for Alembic migrations only:
MIGRATOR_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres?sslmode=require

# Runtime app connections (transaction pooler; asyncpg needs statement_cache_size=0 — handled in db.py):
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
SYNC_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
# Inference API/worker (same pooler URL as SYNC_DATABASE_URL)
INFERENCE_DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# --- Storage (private bucket for document part page images) ---
STORAGE_BACKEND=supabase
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=document-media

# WebP encoding (lossless by default for OCR fidelity)
MEDIA_WEBP_LOSSLESS=true
# MEDIA_WEBP_QUALITY=95

# --- App secrets (generate for each environment) ---
ENVIRONMENT=development
JWT_SECRET=replace-with-at-least-32-byte-secret
CORS_ORIGINS=http://localhost:5173,https://app.nomicous.com

INFERENCE_URL=http://localhost:8001
INFERENCE_WEBHOOK_SECRET=replace-me
INFERENCE_SERVICE_SECRET=replace-me
