# Persistent platform job worker. Copy values into the worker host/provider
# secret store; do not commit a filled file or give this process API, storage,
# JWT, or migration credentials.
ENVIRONMENT=production
DATABASE_URL=
SYNC_DATABASE_URL=

INFERENCE_URL=https://inference.nomicous.com
INFERENCE_WEBHOOK_SECRET=
INFERENCE_SERVICE_SECRET=

JOB_WORKER_ENABLED=true
JOB_SSE_NOTIFICATIONS_ENABLED=false
ENABLE_TEST_JOB_ROUTES=false
