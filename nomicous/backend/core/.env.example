ENVIRONMENT=development
# Match NOMICOUS_DATABASE_PASSWORD to POSTGRES_PASSWORD in the ignored root
# `.env` used by Compose. The nested `${...}` values are expanded by
# python-dotenv; do not put an actual password in this template.
NOMICOUS_DATABASE_USER=postgres
NOMICOUS_DATABASE_PASSWORD=replace-with-a-local-only-password
NOMICOUS_DATABASE_NAME=kalamos
DATABASE_URL=postgresql+asyncpg://${NOMICOUS_DATABASE_USER}:${NOMICOUS_DATABASE_PASSWORD}@localhost:5433/${NOMICOUS_DATABASE_NAME}
SYNC_DATABASE_URL=postgresql://${NOMICOUS_DATABASE_USER}:${NOMICOUS_DATABASE_PASSWORD}@localhost:5433/${NOMICOUS_DATABASE_NAME}
MIGRATOR_DATABASE_URL=postgresql://${NOMICOUS_DATABASE_USER}:${NOMICOUS_DATABASE_PASSWORD}@localhost:5433/${NOMICOUS_DATABASE_NAME}
JWT_SECRET=dev-only-local-jwt-secret-at-least-32-bytes
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
AUTH_RATE_LIMIT_REQUESTS=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
MEDIA_ROOT=./backend/media
# STORAGE_BACKEND=local
# For Supabase Storage instead of local files, see backend/core/.env.supabase.example
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
BEHIND_PROXY=false
FORWARDED_ALLOW_IPS=
# Set to true only in development/test environments; never enable in production.
ENABLE_TEST_JOB_ROUTES=false
# Direct local API development runs its worker and SSE listener in-process.
# Docker Compose instead starts platform-worker separately and disables both on api.
JOB_WORKER_ENABLED=true
JOB_SSE_NOTIFICATIONS_ENABLED=true
JOB_POLL_INTERVAL_SECONDS=0.25
JOB_POLL_MAX_INTERVAL_SECONDS=2.0
JOB_WORKER_CLAIM_TEST_ONLY=
JOB_WORKER_RUNNING_TIMEOUT_SECONDS=1800
INFERENCE_URL=http://localhost:8001
# Model catalog defaults can be UUIDs or stable names seeded into inference_models.
DEFAULT_SEGMENT_MODEL=kraken-segment-default
DEFAULT_TRANSCRIBE_MODEL=kraken-transcribe-default
# Keep model weights in the repository-level model/ workspace or another local path.
KRAKEN_MODEL_PATH=../model/kraken
INFERENCE_URL=http://localhost:8001
INFERENCE_WEBHOOK_SECRET=dev-inference-webhook-secret
INFERENCE_SERVICE_SECRET=dev-inference-webhook-secret
