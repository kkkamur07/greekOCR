# Cloud inference containers only. Copy to backend/core/.env.inference for the
# Supabase Docker profile. Never commit the filled file.
#
# This is deliberately separate from .env.supabase: the inference API and
# worker do not need app JWT, storage, migration, or Supabase service-role
# credentials.
ENVIRONMENT=production

# Transaction-pooler URL for the least-privilege inference worker/API role.
# Fill only in the host/provider secret store.
INFERENCE_DATABASE_URL=

# HTTPS is required for production callbacks except within local Docker Compose,
# where http://api:8000/internal/inference/job-complete is permitted.
INFERENCE_CALLBACK_URL=https://api.nomicous.com/internal/inference/job-complete

# Must match the platform API's INFERENCE_WEBHOOK_SECRET and
# INFERENCE_SERVICE_SECRET values for this environment.
INFERENCE_WEBHOOK_SECRET=replace-me
INFERENCE_SERVICE_SECRET=replace-me
