# Copy to .env and adjust for local development.
# Relative paths resolve from the nomicous/ app root unless noted.

# Filesystem root (relative paths resolve from nomicous/ project root; default: data)
NOMICOUS_DATA_ROOT=data

# Local API bind (uvicorn when not using Docker)
NOMICOUS_HOST=127.0.0.1
NOMICOUS_PORT=5050

# Comma-separated browser origins for CORS
NOMICOUS_CORS_ORIGINS=http://localhost:3000

# Hot reload for local uvicorn
NOMICOUS_RELOAD=true
