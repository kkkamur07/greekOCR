{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b tsconfig.api.json && vite build",
    "typecheck": "tsc -b",
    "typecheck:api": "tsc -b tsconfig.api.json",
